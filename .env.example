# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=interviewiq
DB_USER=interviewiq_user
DB_PASSWORD=interviewiq_password

# MongoDB Configuration
MONGODB_URI=mongodb+srv://nicolates1711_db_user:<db_password>@cluster0.9bpa7yo.mongodb.net/?appName=Cluster0
MONGODB_DATABASE=interviewiq_auth
MONGODB_PASSWORD=your_mongodb_password

# Spring Boot Configuration
SPRING_PROFILES_ACTIVE=production
SERVER_PORT=8080

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-for-production-change-this
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# Email Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Swagger/OpenAPI Configuration
SPRINGDOC_API_DOCS_ENABLED=true
SPRINGDOC_SWAGGER_UI_ENABLED=true

# Frontend Configuration
VITE_API_URL=http://localhost:8080/api
VITE_APP_NAME=InterviewIQ
VITE_APP_VERSION=1.0.0

# Production Configuration
NODE_ENV=production
REACT_APP_API_URL=https://api.yourdomain.com
