PORT=8081
NODE_ENV=development
FRONTEND_URLS=http://localhost:5173,http://localhost:3000
MONGODB_URI=mongodb://<user>:<password>@host1:27017,host2:27017,host3:27017/?ssl=true&authSource=admin&replicaSet=<replica-set>&retryWrites=true&w=majority
MONGODB_DB=interviewiq
JWT_SECRET=replace_with_long_random_secret
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# Firebase Admin service account values
FIREBASE_PROJECT_ID=projecthell-1
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_WEB_API_KEY=
